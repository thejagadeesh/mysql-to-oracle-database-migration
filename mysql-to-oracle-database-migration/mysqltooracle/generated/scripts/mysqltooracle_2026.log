  2  BEFORE INSERT OR UPDATE ON film
  3  FOR EACH ROW
  4  DECLARE
  5    v_val film.rating%TYPE;
  6    v_test film.rating%TYPE;
  7  BEGIN
  8    v_val := null;
  9    v_test := TRIM(:new.rating);
 10    if v_test = '1' OR v_test = 'G' THEN 
 11    v_val := 'G';
 12    elsif v_test = '2' OR v_test = 'PG' THEN 
 13    v_val := 'PG';
 14    elsif v_test = '3' OR v_test = 'PG-13' THEN 
 15    v_val := 'PG-13';
 16    elsif v_test = '4' OR v_test = 'R' THEN 
 17    v_val := 'R';
 18    elsif v_test = '5' OR v_test = 'NC-17' THEN 
 19    v_val := 'NC-17';
 20    end if;  :new.rating := v_val;
 21  END;
