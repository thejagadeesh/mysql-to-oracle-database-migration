  2  BEFORE INSERT OR UPDATE ON film
  3  FOR EACH ROW
  4  DECLARE
  5    input varchar2(500);
  6    val varchar2(50);
  7    cnt number := 1;
  8    num number := 0;
  9    str VARCHAR2(50);
 10    returnStr varchar2(500);
 11    setValue number :=0;
 12    type array_value is table of number index by varchar2(40);
 13    value_array array_value;
 14    type array_order is table of varchar2(40) index by BINARY_INTEGER;
 15    order_array array_order;
 16  BEGIN
 17  value_array('Trailers') := 0;
 18  value_array('Commentaries') := 0;
 19  value_array('Deleted Scenes') := 0;
 20  value_array('Behind the Scenes') := 0;
 21  order_array(0) :='Trailers';
 22  order_array(1) :='Commentaries';
 23  order_array(2) :='Deleted Scenes';
 24  order_array(3) :='Behind the Scenes';
 25  
 26  input := TRIM(:new.special_features);
 27  LOOP
 28    val := getTokenizer(input,cnt);
 29    cnt := cnt + 1;
 30    if val is not null then 
 31       if value_array.exists(val) then
 32          value_array(val) := 1;
 33       end if;
 34    else
 35       exit;
 36    end if;
 37  end loop;
 38  num := order_array.FIRST;
 39  LOOP
 40    EXIT WHEN NOT order_array.EXISTS(num);
 41    str := order_array(num);
 42    setValue := value_array(str);
 43    if (setValue = 1) then
 44      if returnStr is null then
 45        returnStr := str;
 46      else
 47        returnStr := returnStr || ',' || str;
 48      end if;
 49    end if;
 50    num := order_array.next(num);
 51  END LOOP;
 52  
 53  returnStr := substr(returnStr,0,length(returnStr));
 54  if returnStr is not null then
 55    :new.special_features := returnStr;
 56  else
 57    :new.special_features := ' ';
 58  END IF;
 59  END;
 60  
 61  /
