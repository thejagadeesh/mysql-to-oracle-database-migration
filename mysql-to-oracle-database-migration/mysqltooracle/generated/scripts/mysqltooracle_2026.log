  2  the_list  varchar2,
  3  the_index number,
  4  delim     varchar2 := ','
  5  )
  6  return    varchar2
  7  is
  8  start_pos number;
  9  end_pos   number;
 10  begin
 11   if the_index = 1 then
 12  start_pos := 1;
 13  else
 14  start_pos := instr(the_list,delim,1,the_index - 1);
 15  if start_pos = 0 then
 16  return null;
 17  else
 18  start_pos := start_pos + length(delim);
 19  end if;
 20  end if;
 21  end_pos := instr(the_list,delim,start_pos,1);
 22  if end_pos = 0 then
 23  return substr(the_list,start_pos);
 24  else
 25  return substr(the_list,start_pos,end_pos - start_pos);
 26  end if;
 27  end getTokenizer;
